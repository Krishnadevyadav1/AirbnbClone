<% layout("/layouts/boilerplate") -%>
<body>
<div class="row mt-3">
<div class="col-8 offset-2 ">
     <h3>Edit listing </h3><br>
    <form method="post" action="/listing/<%=list._id%>/edit?_method=put" novalidate class="needs-validation">
        <div class="mb-3">
        <label for="title" class="form-label">Title:</label>
        <input class="form-control" value="<%=list.title%>" name="listing[title]" required>
        <div class="invalid-feedback">Title is required</div><br><br>
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">Description:</label>
        <textarea required class="form-control" name="listing[description]"><%=list.description%></textarea>
        <div class="invalid-feedback">Description is required</div><br><br>
        </div>
        <div class="mb-3">
            <label for="image" class="form-label">Image link:</label>
        <input class="form-control" value="<%=list.image.url%>"name="listing[images]">
        <div class="invalid-feedback">Image is required</div><br><br>
        </div>
<div class="row">
        <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price:</label>
       <input required class="form-control" value="<%=list.price%>" name="listing[price]">
       <div class="invalid-feedback">Price is required</div><br><br>
       </div>
       <div class="mb-3 col-md-8">
         <label for="location" class="form-label">Location:</label>
       <input required class="form-control"  value="<%=list.location%>" name="listing[location]">
       <div class="invalid-feedback">Location is required</div><br><br>
       </div>
</div>
       <div class="mb-3">
                 <label for="country" class="form-label">County:</label>
        <input required class="form-control"   value="<%=list.country%>" name="listing[country]">
        <div class="invalid-feedback">Country is required</div>

    </div>
        <button class="btn btn-dark  edit-btn  mt-3">save</button>
    </form>
    </div>
</div>
</body>
